        "id": "L5xecmTH5ft5",
        "outputId": "a9696a95-4120-4140-ffb7-ed665f49b6fa"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Best parameters: {'C': 0.1, 'max_iter': 100, 'tol': 0.001}\n",
            "Best score: 0.9348878777081374\n"
          ]
        }
      ],
      "source": [
        "# Hyperparameter Tuning with GridSearchCV (for TfidfVectorizer with PassiveAggressiveClassifier)\n",
        "from sklearn.model_selection import GridSearchCV\n",
        "\n",
        "param_grid = {\n",
        "    'max_iter': [100, 500, 1000],\n",
        "    'C': [0.1, 1, 10],\n",
        "    'tol': [1e-3, 1e-4, 1e-5]\n",
        "}\n",
        "\n",
        "grid_search = GridSearchCV(pac2, param_grid, cv=5, scoring='accuracy')\n",
        "grid_search.fit(x_train_combined, y_train)\n",
        "\n",
        "# Get the best parameters and score\n",
        "print(f\"Best parameters: {grid_search.best_params_}\")\n",
        "print(f\"Best score: {grid_search.best_score_}\")"
      ]
    },
